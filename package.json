    "lodash": "^4.17.21",
    "lz-string": "^1.5.0",
    "mapbox-gl": "^3.7.0",
    "next": "^15.1.3",
    "next-auth": "^5.0.0-beta.20",
    "next-pwa": "^5.6.0",
    "nodemailer": "^7.0.7",
    "pg": "^8.12.0",
    "prisma": "^5.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "react-map-gl": "^7.1.8",
    "recharts": "^2.14.2",
